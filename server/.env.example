# ============================================================
# SERVER
# ============================================================
PORT=5000

# ============================================================
# URLS
# ============================================================
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
# Set to root domain in production (e.g. .fishoria.online) for cross-subdomain cookies
COOKIE_DOMAIN=.example.com

# ============================================================
# DATABASE (Supabase PostgreSQL)
# ============================================================
# Get connection strings at: https://supabase.com/dashboard/project/<project>/settings/database
# Use DATABASE_URL for direct connection, POOLER_DATABASE_URL for serverless/edge
DATABASE_URL=postgres://<username>:<password>@db.<project_id>.supabase.co:5432/<dbname>
POOLER_DATABASE_URL=postgres://<username>:<password>@pooler.<project_id>.supabase.co:6543/<dbname>

# ============================================================
# REDIS (Upstash)
# ============================================================
# Get credentials at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://<your_redis_id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your_redis_token>

# ============================================================
# GOOGLE OAUTH
# ============================================================
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=<your_client_id>.apps.googleusercontent.com
GOOGLE_SECRET=<your_client_secret>
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# ============================================================
# JWT
# ============================================================
# Generate strong secrets with: openssl rand -hex 64
JWT_SECRET=<your_jwt_secret>
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d
JWT_RESET_SECRET=<your_jwt_reset_secret>
JWT_RESET_TOKEN_EXPIRATION=15m

# ============================================================
# SMTP (Mail)
# ============================================================
# Gmail: enable 2FA and generate an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_USER=<your_email@gmail.com>
SMTP_PASSWORD=<your_app_password>
