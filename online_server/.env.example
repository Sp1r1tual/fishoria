# ============================================================
# SERVER
# ============================================================
PORT=5001

# ============================================================
# URLS
# ============================================================
API_URL=http://localhost:5001
CLIENT_URL=http://localhost:5173

# ============================================================
# DATABASE (Supabase PostgreSQL)
# ============================================================
# Get connection strings at: https://supabase.com/dashboard/project/<project>/settings/database
DATABASE_URL=postgres://<username>:<password>@db.<project_id>.supabase.co:5432/<dbname>
POOLER_DATABASE_URL=postgres://<username>:<password>@pooler.<project_id>.supabase.co:6543/<dbname>

# ============================================================
# REDIS (Upstash)
# ============================================================
# Get credentials at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://<your_redis_id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your_redis_token>
