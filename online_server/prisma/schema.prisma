generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PLAYER
  MODERATOR
}

model User {
  id                  String               @id @default(uuid())
  googleId            String?              @unique
  email               String               @unique
  password            String?
  username            String?
  avatar              String?
  isActivated         Boolean              @default(false)
  activationLink      String?              @unique
  role                UserRole             @default(PLAYER)
  language            String               @default("en")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  bans                UserBan[]            @relation("BannedUser")
  bansIssued          UserBan[]            @relation("BannedByModerator")
  profile             PlayerProfile?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([createdAt])
  @@index([role])
  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model UserBan {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  reason     String
  bannedById String
  bannedBy   User      @relation("BannedByModerator", fields: [bannedById], references: [id], onDelete: Cascade)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([bannedById])
  @@index([userId, expiresAt])
  @@map("user_bans")
}

model PlayerProfile {
  id                 String              @id @default(uuid())
  userId             String              @unique
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  level              Int                 @default(1)
  xp                 Int                 @default(0)
  money              Int                 @default(100000)
  equippedRodUid     String?
  equippedReelUid    String?
  equippedLineUid    String?
  equippedHookUid    String?
  hasEchoSounder     Boolean             @default(false)
  activeBait         String              @default("worm")
  activeGroundbait   String              @default("none")
  gearItems          GearItem[]
  consumables        ConsumableItem[]
  fishCatches        FishCatch[]
  lakeStats          LakeStatistic[]
  playerQuests       PlayerQuest[]
  playerAchievements PlayerAchievement[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@map("player_profiles")
}

model GearItem {
  uid       String        @id @default(uuid())
  profileId String
  profile   PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  itemType  String
  itemId    String
  condition Float?
  meters    Float?
  isBroken  Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([profileId])
  @@index([itemType])
  @@index([itemId])
  @@map("gear_items")
}

model ConsumableItem {
  id        String        @id @default(uuid())
  profileId String
  profile   PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  itemType  String
  itemId    String
  quantity  Int           @default(0)

  @@unique([profileId, itemId])
  @@map("consumable_items")
}

model FishCatch {
  id          String        @id @default(uuid())
  profileId   String
  profile     PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  speciesId   String
  speciesName String
  weight      Float
  length      Float
  lakeId      String
  lakeName    String
  baitUsed    String
  method      String        @default("FLOAT")
  isReleased  Boolean       @default(false)

  caughtAt DateTime @default(now())

  @@index([profileId])
  @@index([lakeId])
  @@index([speciesId])
  @@index([caughtAt])
  @@map("fish_catches")
}

model LakeStatistic {
  id             String        @id @default(uuid())
  profileId      String
  profile        PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  lakeId         String
  totalCaught    Int           @default(0)
  totalWeight    Float         @default(0)
  records        Json          @default("{}")
  minWeights     Json          @default("{}")
  speciesCounts  Json          @default("{}")
  speciesWeights Json          @default("{}")

  @@unique([profileId, lakeId])
  @@map("lake_statistics")
}

model News {
  id           String            @id @default(uuid())
  imageUrl     String?
  isPublished  Boolean           @default(true)
  translations NewsTranslation[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([isPublished, createdAt])
  @@map("news")
}

model NewsTranslation {
  id       String @id @default(uuid())
  newsId   String
  news     News   @relation(fields: [newsId], references: [id], onDelete: Cascade)
  language String
  title    String
  content  String @db.Text

  @@unique([newsId, language])
  @@map("news_translations")
}

model Quest {
  id           String             @id @default(uuid())
  imageUrl     String?
  conditions   Json               @default("[]")
  xpReward     Int                @default(0)
  moneyReward  Int                @default(0)
  order        Int                @default(0)
  translations QuestTranslation[]
  playerQuests PlayerQuest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("quests")
}

model QuestTranslation {
  id          String @id @default(uuid())
  questId     String
  quest       Quest  @relation(fields: [questId], references: [id], onDelete: Cascade)
  language    String
  title       String
  description String @db.Text

  @@unique([questId, language])
  @@map("quest_translations")
}

model PlayerQuest {
  id          String        @id @default(uuid())
  profileId   String
  profile     PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  questId     String
  quest       Quest         @relation(fields: [questId], references: [id], onDelete: Cascade)
  progress    Json          @default("{}")
  isCompleted Boolean       @default(false)
  isClaimed   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([profileId, questId])
  @@index([questId])
  @@map("player_quests")
}

model Achievement {
  id                 String                   @id @default(uuid())
  code               String                   @unique
  imageUrl           String?
  order              Int                      @default(0)
  translations       AchievementTranslation[]
  playerAchievements PlayerAchievement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("achievements")
}

model AchievementTranslation {
  id            String      @id @default(uuid())
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  language      String
  title         String
  description   String      @db.Text

  @@unique([achievementId, language])
  @@map("achievement_translations")
}

model PlayerAchievement {
  id            String        @id @default(uuid())
  profileId     String
  profile       PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement   @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())

  @@unique([profileId, achievementId])
  @@index([achievementId])
  @@map("player_achievements")
}
